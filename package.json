{
  "name": "desktop-organizer",
  "version": "1.5.9",
  "description": "Windows桌面图标收纳盒 - 归类整理桌面快捷方式",
  "main": "src/main.js",
  "scripts": {
    "start": "node scripts/start.js",
    "dev": "node scripts/dev.js",
    "app": "node .claude/skills/app-manager/driver.mjs",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "author": "Halo",
  "license": "MIT",
  "devDependencies": {
    "electron": "28.3.3",
    "electron-builder": "^24.9.0",
    "playwright": "^1.60.0",
    "puppeteer-core": "^25.1.0"
  },
  "dependencies": {
    "fs-extra": "^11.2.0"
  },
  "build": {
    "appId": "com.halo.desktop-organizer",
    "productName": "Desktop Organizer",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "deleteAppDataOnUninstall": true,
      "include": "scripts/uninstall.nsh"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "src/ps/**"
    ]
  }
}
